{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "strict": true,
    "rootDir": "src",
    "outDir": "out",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": true,
    "moduleResolution": "node",
    "composite": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "out", "src/**/*.test.ts"]
}
